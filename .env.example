# ============================================================
# Environment variables — NEVER commit this file to git
# Copy to .env and fill in real values for production.
# .env is already in .gitignore.
# ============================================================

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orders_db
DB_USER=orders_user
DB_PASSWORD=orders_pass_change_me_in_prod

# ── JWT ───────────────────────────────────────────────────
# Base64-encoded HS256 secret key (minimum 256 bits / 32 bytes).
# Generate with: openssl rand -base64 32
APP_JWT_SECRET=replace_with_base64_encoded_secret_min_32_bytes
APP_JWT_EXPIRATION_MS=86400000

# ── Grafana ───────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASS=grafana_changeme_in_prod

# =============================================================================
# .dockerignore — controls what the Docker build context includes.
# Excluding unnecessary files reduces context size (faster "docker build") and
# prevents secrets or local state from leaking into the image.
# =============================================================================

# --- Version control ---
# Git metadata is irrelevant inside the image and can leak commit history
.git
.gitignore
.gitattributes

# --- Maven build output ---
# Maven rebuilds everything inside the container; copying a local target/
# directory would shadow the clean build and could include stale artifacts
target/

# --- IDE / editor ---
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store
.classpath
.project
.settings/

# --- Docker tooling ---
# The Dockerfile and compose files describe how to build/run the image;
# they serve no purpose inside the image itself
Dockerfile
Dockerfile.*
.dockerignore
docker-compose*.yml
docker/

# --- Documentation ---
# Runtime containers don't serve docs; excluding them shrinks the build context
*.md
CLAUDE.md
docs/

# --- Load testing ---
k6/

# --- API tooling ---
postman/

# --- Reverse-proxy config (runs in a separate container) ---
nginx/

# --- Environment / secrets ---
# NEVER bake .env files into the image; supply secrets via env vars or secrets
# managers at runtime.  .env.example is allowed as it contains only placeholders.
.env
.env.*
!.env.example

# --- Build / dev scripts ---
Makefile
scripts/

# --- Checkstyle reports (generated by mvn validate) ---
checkstyle-result.xml
checkstyle-cachefile

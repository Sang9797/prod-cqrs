{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "k6 Load Testing — CQRS Order Service",
  "uid": "k6-cqrs-order-service",
  "description": "Real-time k6 load and stress test metrics pushed via Prometheus remote-write.",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "tags": ["k6", "performance", "load-testing"],
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100, "title": "📊 Test Overview", "type": "row" },

    {
      "id": 1, "type": "stat", "title": "Active VUs",
      "description": "Number of virtual users currently running.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "k6_vus", "legendFormat": "VUs", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto", "textMode": "auto", "colorMode": "background",
        "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "short"
        }
      }
    },

    {
      "id": 2, "type": "stat", "title": "Request Rate",
      "description": "Requests per second across all endpoints.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(k6_http_reqs_total[1m]))", "legendFormat": "req/s", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto", "textMode": "auto", "colorMode": "background",
        "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "reqps", "decimals": 1
        }
      }
    },

    {
      "id": 3, "type": "stat", "title": "Error Rate",
      "description": "Percentage of failed HTTP requests. SLO: < 1 %.",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "k6_http_req_failed_rate * 100", "legendFormat": "errors %", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto", "textMode": "auto", "colorMode": "background",
        "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "percent", "decimals": 2,
          "max": 100, "min": 0
        }
      }
    },

    {
      "id": 4, "type": "stat", "title": "p95 Latency (all)",
      "description": "95th-percentile response time across all endpoints. SLO: < 300 ms.",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "k6_http_req_duration_p95", "legendFormat": "p95 ms", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto", "textMode": "auto", "colorMode": "background",
        "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 300 }
            ]
          },
          "unit": "ms"
        }
      }
    },

    {
      "id": 5, "type": "stat", "title": "Order Lifecycle Success",
      "description": "Percentage of end-to-end order flows (create → confirm/cancel) that completed without any step failing. SLO: > 95 %.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "k6_order_lifecycle_success_rate * 100", "legendFormat": "success %", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto", "textMode": "auto", "colorMode": "background",
        "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent", "decimals": 1,
          "max": 100, "min": 0
        }
      }
    },

    {
      "id": 6, "type": "stat", "title": "Total Requests",
      "description": "Total HTTP requests sent during the test window.",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(increase(k6_http_reqs_total[$__range]))", "legendFormat": "total", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto", "textMode": "auto", "colorMode": "value",
        "graphMode": "none", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      }
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101, "title": "⏱ Latency", "type": "row" },

    {
      "id": 10, "type": "timeseries", "title": "Response Time Percentiles",
      "description": "p50 / p90 / p95 / p99 latency over time across all endpoints.",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "k6_http_req_duration_p50", "legendFormat": "p50", "refId": "A" },
        { "expr": "k6_http_req_duration_p90", "legendFormat": "p90", "refId": "B" },
        { "expr": "k6_http_req_duration_p95", "legendFormat": "p95", "refId": "C" },
        { "expr": "k6_http_req_duration_p99", "legendFormat": "p99", "refId": "D" }
      ],
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p90" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },

    {
      "id": 11, "type": "bargauge", "title": "p95 Latency by Endpoint",
      "description": "Current p95 response time broken down per endpoint tag.",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "k6_http_req_duration_p95{endpoint!=\"\"}",
          "legendFormat": "{{endpoint}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "legend": { "displayMode": "hidden" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "orange", "value": 250 },
              { "color": "red", "value": 300 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 102, "title": "📈 Throughput & Load", "type": "row" },

    {
      "id": 20, "type": "timeseries", "title": "Virtual Users (VUs)",
      "description": "Number of active VUs over time — shows the ramping profile.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "k6_vus", "legendFormat": "Active VUs", "refId": "A" },
        { "expr": "k6_vus_max", "legendFormat": "Max VUs", "refId": "B" }
      ],
      "options": {
        "legend": { "calcs": ["max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Max VUs" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    },

    {
      "id": 21, "type": "timeseries", "title": "Request Rate (req/s)",
      "description": "HTTP requests per second. Use this to correlate throughput with latency spikes.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(k6_http_reqs_total[1m]))", "legendFormat": "All endpoints", "refId": "A" },
        { "expr": "rate(k6_http_reqs_total{endpoint!=\"\"}[1m])", "legendFormat": "{{endpoint}}", "refId": "B" }
      ],
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 22, "type": "timeseries", "title": "Error Rate",
      "description": "Proportion of failed requests over time. The red threshold line marks the 1 % SLO.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "k6_http_req_failed_rate * 100", "legendFormat": "Error %", "refId": "A" }
      ],
      "options": {
        "legend": { "calcs": ["max", "lastNotNull"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 103, "title": "🛒 Order Business Metrics", "type": "row" },

    {
      "id": 30, "type": "timeseries", "title": "Order Create Latency",
      "description": "p50 / p95 / p99 latency of the POST /orders endpoint specifically.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "k6_order_create_latency_ms_p50", "legendFormat": "p50", "refId": "A" },
        { "expr": "k6_order_create_latency_ms_p95", "legendFormat": "p95", "refId": "B" },
        { "expr": "k6_order_create_latency_ms_p99", "legendFormat": "p99", "refId": "C" }
      ],
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 400 }
            ]
          }
        }
      }
    },

    {
      "id": 31, "type": "timeseries", "title": "Order Confirm Latency",
      "description": "p50 / p95 / p99 latency of the POST /orders/{id}/confirm endpoint.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "k6_order_confirm_latency_ms_p50", "legendFormat": "p50", "refId": "A" },
        { "expr": "k6_order_confirm_latency_ms_p95", "legendFormat": "p95", "refId": "B" },
        { "expr": "k6_order_confirm_latency_ms_p99", "legendFormat": "p99", "refId": "C" }
      ],
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 32, "type": "timeseries", "title": "Order Lifecycle Success Rate",
      "description": "End-to-end success rate of the full create→confirm/cancel scenario. SLO: > 95 %.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "k6_order_lifecycle_success_rate * 100", "legendFormat": "Success %", "refId": "A" }
      ],
      "options": {
        "legend": { "calcs": ["min", "lastNotNull"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "thresholdsStyle": { "mode": "line" }
          },
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 104, "title": "🌐 Network", "type": "row" },

    {
      "id": 40, "type": "timeseries", "title": "Data Throughput",
      "description": "Bytes sent to and received from the server per second.",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(k6_data_received_total[1m])", "legendFormat": "Received", "refId": "A" },
        { "expr": "rate(k6_data_sent_total[1m])", "legendFormat": "Sent", "refId": "B" }
      ],
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 41, "type": "timeseries", "title": "Iterations per Second",
      "description": "Complete scenario iterations executed per second across all VUs.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(k6_iterations_total[1m])", "legendFormat": "iterations/s", "refId": "A" }
      ],
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    }

  ]
}
